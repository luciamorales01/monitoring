# General
NODE_ENV=development

# API
PORT=3000
GLOBAL_PREFIX=api
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change-me-use-a-long-random-secret
JWT_EXPIRES_IN=1d

# Database
POSTGRES_DB=monitoring
POSTGRES_USER=monitoring
POSTGRES_PASSWORD=monitoring
DATABASE_URL=postgresql://monitoring:monitoring@localhost:5432/monitoring
DIRECT_URL=postgresql://monitoring:monitoring@localhost:5432/monitoring

# Redis / queues
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Web
VITE_API_URL=http://localhost:3000/api
