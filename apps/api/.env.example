# Base de datos PostgreSQL
DATABASE_URL="postgresql://monitoring:monitoring@localhost:5432/monitoring"
# En Supabase suele ser la URL directa/no-pooled. Si no la usas, puedes repetir DATABASE_URL.
DIRECT_URL="postgresql://monitoring:monitoring@localhost:5432/monitoring"

# API
API_PORT=3000
API_PREFIX=api
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
NODE_ENV=development

# JWT: usa un secreto largo, aleatorio y diferente por entorno
JWT_SECRET="change-me-use-a-long-random-secret-with-32-chars-minimum"
JWT_EXPIRES_IN=3600
JWT_REMEMBER_ME_EXPIRES_IN=31536000
JWT_REFRESH_EXPIRES_IN=31536000
