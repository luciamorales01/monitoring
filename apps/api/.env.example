DATABASE_URL="postgresql://monitoring:monitoring@localhost:5432/monitoring"
DIRECT_URL="postgresql://monitoring:monitoring@localhost:5432/monitoring"
JWT_SECRET="change-me-use-a-long-random-secret-at-least-32-chars"
JWT_EXPIRES_IN=1d
API_PORT=3000
API_PREFIX=api
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
NODE_ENV=development
APP_NAME=Monitoring

# Email alerts. Leave empty in local dev if you only want notification history as SKIPPED.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Monitoring <alerts@example.com>"

# Auth avanzado
JWT_REFRESH_EXPIRES_IN=86400
JWT_REMEMBER_ME_EXPIRES_IN=31536000
PASSWORD_RESET_TOKEN_MINUTES=30
APP_URL=http://localhost:5173
