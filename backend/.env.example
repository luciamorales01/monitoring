# General
NODE_ENV=development

# API
API_PORT=3000
API_PREFIX=api
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET=change-me-use-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=1d

# Database
POSTGRES_DB=monitoring
POSTGRES_USER=monitoring
POSTGRES_PASSWORD=monitoring
DATABASE_URL=postgresql://monitoring:monitoring@localhost:5433/monitoring
DIRECT_URL=postgresql://monitoring:monitoring@localhost:5433/monitoring

# Redis / queues
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email / notifications worker
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true

SMTP_USER=
SMTP_PASS=

NOTIFICATIONS_FROM="Monitoring Alerts <no-reply@monitoringapp.es>"

FRONTEND_URL=http://localhost:5173
