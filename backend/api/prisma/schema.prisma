generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  monitors  Monitor[]
  refreshTokens RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  invitations UserInvitation[]
  sections  Section[]
}

model User {
  id             Int      @id @default(autoincrement())
  name           String
  email          String   @unique
  passwordHash   String
  role           UserRole @default(VIEWER)
  organizationId Int
  phone          String   @default("")
  timezone       String   @default("Europe/Madrid")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdMonitors Monitor[]
  refreshTokens RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  invitedUsers UserInvitation[] @relation("InvitationAcceptedUser")
  sectionMemberships SectionMember[]

  status UserStatus @default(ACTIVE)
  lastLoginAt DateTime?
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum MonitorType {
  HTTP
  HTTPS
}

enum MonitorStatus {
  UP
  DOWN
  UNKNOWN
}

enum IncidentStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Monitor {
  id                 Int           @id @default(autoincrement())
  name               String
  type               MonitorType   @default(HTTPS)
  target             String
  expectedStatusCode Int           @default(200)
  frequencySeconds   Int           @default(60)
  timeoutSeconds     Int           @default(10)
  currentStatus      MonitorStatus @default(UNKNOWN)
  lastResponseTime   Int?
  lastCheckedAt      DateTime?
  nextCheckAt        DateTime      @default(now())
  isActive           Boolean       @default(true)
  usesSectionSchedule Boolean      @default(true)

  organizationId     Int
  createdById        Int

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  organization       Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy          User          @relation(fields: [createdById], references: [id])
  checkResults       CheckResult[]
  incidents          Incident[]
  notificationEvents NotificationEvent[]

  @@index([isActive, nextCheckAt])

  alertEmail     Boolean  @default(true)
  alertThreshold Int      @default(3)

  sections  SectionMonitor[]
}

enum UserRole {
  OWNER
  ADMIN
  VIEWER
}

model CheckResult {
  id             Int           @id @default(autoincrement())
  monitorId      Int
  status         MonitorStatus
  responseTimeMs Int?
  statusCode     Int?
  errorMessage   String?
  checkedAt      DateTime      @default(now())

  monitor        Monitor       @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId, checkedAt])
}

model Incident {
  id                 Int              @id @default(autoincrement())
  monitorId          Int
  status             IncidentStatus   @default(OPEN)
  severity           IncidentSeverity @default(HIGH)
  title              String
  startedAt          DateTime
  acknowledgedAt     DateTime?
  acknowledgedById   Int?
  resolvedAt         DateTime?
  resolvedById       Int?
  durationSeconds    Int?
  resolutionNote     String?
  rootCause          String?
  lastStatusChangeAt DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  monitor            Monitor          @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  notificationEvents NotificationEvent[]

  @@index([monitorId, status])
  @@index([status, startedAt])
  @@index([severity, status])
}


enum NotificationType {
  MONITOR_DOWN
  MONITOR_RECOVERED
}

enum NotificationChannel {
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model NotificationEvent {
  id           Int                 @id @default(autoincrement())
  monitorId    Int
  incidentId   Int?
  type         NotificationType
  channel      NotificationChannel @default(EMAIL)
  status       NotificationStatus  @default(PENDING)
  recipient    String?
  subject      String?
  errorMessage String?
  sentAt       DateTime?
  createdAt    DateTime            @default(now())

  monitor      Monitor             @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  incident     Incident?           @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  @@index([monitorId, createdAt])
  @@index([incidentId])
  @@index([type, status])

  readAt DateTime?
}


model RefreshToken {
  id             Int      @id @default(autoincrement())
  userId         Int
  organizationId Int
  tokenHash      String   @unique
  rememberMe     Boolean  @default(false)
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
}


model UserInvitation {
  id             Int        @id @default(autoincrement())
  email          String
  role           UserRole   @default(VIEWER)
  tokenHash      String     @unique
  organizationId Int
  invitedById    Int?
  acceptedById   Int?       @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  acceptedBy   User?        @relation("InvitationAcceptedUser", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([organizationId, email])
  @@index([tokenHash])
  @@index([expiresAt])
}

model PasswordResetToken {
  id             Int      @id @default(autoincrement())
  userId         Int
  organizationId Int
  tokenHash      String   @unique
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@index([expiresAt])
}

model Section {
  id             Int              @id @default(autoincrement())
  name           String
  description    String           @default("")
  icon           String           @default("folder")
  expectedStatusCode Int           @default(200)
  frequencySeconds   Int           @default(60)
  timeoutSeconds     Int           @default(10)
  isActive       Boolean          @default(true)
  organizationId Int
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  monitors       SectionMonitor[]
  members        SectionMember[]

  @@index([organizationId])
}

model SectionMember {
  sectionId Int
  userId    Int
  createdAt DateTime @default(now())

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sectionId, userId])
  @@index([userId])
}

model SectionMonitor {
  sectionId  Int
  monitorId  Int
  assignedAt DateTime @default(now())

  section    Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  monitor    Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@id([sectionId, monitorId])
  @@index([monitorId])
}
